---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
  canonicalPath?: string;
  ogImage?: string;
}

const { title, description, canonicalPath, ogImage } = Astro.props;
const siteUrl = (import.meta.env.SITE ?? Astro.site?.toString() ?? "").replace(/\/$/, "");
const canonicalUrl = canonicalPath ? `${siteUrl}${canonicalPath}` : undefined;
const DEFAULT_OG_IMAGE = "/assets/current/hotel/645740576_1480793004051426_5360198729458927980_n.jpg";
const ogImageUrl = `${siteUrl}${ogImage ?? DEFAULT_OG_IMAGE}`;
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Hotel Zacisze Turawa" />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Structured data -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Hotel",
      "name": "Hotel Zacisze",
      "url": siteUrl,
      "logo": `${siteUrl}/zacisze-logo.svg`,
      "image": ogImageUrl,
      "description": "Hotel Zacisze ★★★ w Turawie — 150 m od plaży Jeziora Turawskiego. Strefa SPA, restauracja z kuchnią regionalną, sale konferencyjne do 150 osób.",
      "starRating": { "@type": "Rating", "ratingValue": "3" },
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "ul. Biwakowa 2",
        "addressLocality": "Turawa",
        "postalCode": "46-045",
        "addressCountry": "PL"
      },
      "telephone": "+48774029030",
      "email": "biuro@zaciszeturawa.pl",
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 50.7192,
        "longitude": 18.0647
      },
      "amenityFeature": [
        { "@type": "LocationFeatureSpecification", "name": "Strefa SPA", "value": true },
        { "@type": "LocationFeatureSpecification", "name": "Restauracja", "value": true },
        { "@type": "LocationFeatureSpecification", "name": "Sale konferencyjne", "value": true },
        { "@type": "LocationFeatureSpecification", "name": "Basen zewnętrzny", "value": true },
        { "@type": "LocationFeatureSpecification", "name": "Sauna fińska", "value": true },
        { "@type": "LocationFeatureSpecification", "name": "Jacuzzi", "value": true },
        { "@type": "LocationFeatureSpecification", "name": "Grota solna", "value": true },
        { "@type": "LocationFeatureSpecification", "name": "Parking", "value": true }
      ],
      "numberOfRooms": 75,
      "checkinTime": "14:00",
      "checkoutTime": "12:00",
      "sameAs": [
        "https://www.facebook.com/hotelzacisze",
        "https://www.instagram.com/hotelzacisze"
      ]
    })} />

    <link rel="icon" type="image/svg+xml" href="/zacisze-favicon.svg" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#231c1a" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Host+Grotesk:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Przejdź do treści</a>
    <Header />
    <div id="main-content">
      <slot />
    </div>
    <Footer />
  </body>
</html>

<style is:global>
  :root {
    --bg: #f6f1ea;
    --text: #131210;
    --text-secondary: #3c3121;
    --muted: #cdc0b1;
    --surface: #fafafa;
    --dark: #231c1a;

    --font-heading: "Libre Baskerville", Georgia, serif;
    --font-body: "Host Grotesk", system-ui, sans-serif;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.6;
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-heading);
    line-height: 1.25;
  }

  img {
    max-width: 100%;
    height: auto;
    display: block;
  }

  a {
    color: inherit;
  }

  .skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    padding: 0.5rem 1rem;
    background: var(--dark);
    color: var(--surface);
    font-size: 0.875rem;
    text-decoration: none;
    z-index: 9999;
    border: 1px solid var(--surface);
  }

  .skip-link:focus {
    top: 1rem;
  }
</style>
