---
import BaseLayout from "../layouts/BaseLayout.astro";

const photos = [
  { src: "/assets/current/hotel/Copy of Copy of Zacisze7.jpg", alt: "Śniadanie bufetowe" },
  { src: "/assets/current/hotel/Copy of Copy of Zacisze11.jpg", alt: "Wypieki domowe" },
  { src: "/assets/current/hotel/Copy of Copy of Zacisze9.jpg", alt: "Wielkanocny stół bufetowy" },
  { src: "/assets/current/hotel/Copy of Copy of Zacisze34.jpg", alt: "Sałatka z kurczakiem na tarasie" },
  { src: "/assets/current/hotel/Copy of Copy of Zacisze41.jpg", alt: "Przekąski i piwo na tarasie" },
  { src: "/assets/current/hotel/Copy of Copy of Zacisze43.jpg", alt: "Talerz przystawek w ogrodzie" },
];

const hours = [
  { label: "Śniadania pn–pt", value: "7:30–9:30" },
  { label: "Śniadania sob–niedz i święta", value: "8:30–10:30" },
  { label: "Lunch i kolacja (restauracja)", value: "15:00–21:00" },
  { label: "Niedziela — restauracja od", value: "13:00" },
];
---

<BaseLayout
  title="Restauracja — Hotel Zacisze ★★★ Turawa"
  description="Restauracja Hotelu Zacisze serwuje śniadania i dania z regionalnej kuchni. Sala bankietowa do 100 osób — wesela, komunie, uroczystości. Turawa k. Opola."
  canonicalPath="/restauracja"
  ogImage="/assets/current/hotel/Copy of Copy of Zacisze7.jpg"
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FoodEstablishment",
    "name": "Restauracja Hotel Zacisze",
    "url": "https://zaciszeturawa.com/restauracja",
    "image": "https://zaciszeturawa.com/assets/current/hotel/Copy of Copy of Zacisze7.jpg",
    "servesCuisine": "European, Regional Polish",
    "priceRange": "$$",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "ul. Biwakowa 2",
      "addressLocality": "Turawa",
      "postalCode": "46-045",
      "addressCountry": "PL"
    },
    "telephone": "+48774029030",
    "openingHoursSpecification": [
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
        "opens": "07:30",
        "closes": "21:00"
      },
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Saturday"],
        "opens": "08:30",
        "closes": "21:00"
      },
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Sunday"],
        "opens": "08:30",
        "closes": "21:00"
      }
    ],
    "menu": "https://zaciszeturawa.com/restauracja",
    "acceptsReservations": "True"
  })} />

  <!-- HERO -->
  <header class="rest-hero">
    <img
      src="/assets/current/hotel/Copy of Copy of Zacisze7.jpg"
      alt="Śniadanie bufetowe w restauracji Hotelu Zacisze"
      class="rest-hero-img"
      fetchpriority="high"
      decoding="async"
    />
    <div class="rest-hero-inner">
      <p class="kicker">Restauracja</p>
      <h1>Smak regionu, atmosfera natury</h1>
    </div>
  </header>

  <!-- HOURS STRIP -->
  <section class="hours-strip">
    <div class="hours-strip-inner">
      {hours.map((h) => (
        <div class="hours-item">
          <span class="hours-label">{h.label}</span>
          <span class="hours-value">{h.value}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- INTRO -->
  <section class="rest-intro">
    <div class="rest-intro-inner">
      <div class="rest-intro-text">
        <h2>Kuchnia z pasją</h2>
        <p>Nasza restauracja serwuje codzienne śniadania w ramach noclegu — zapraszamy też Gości spoza hotelu. Doświadczeni kucharze dbają o wyśmienity smak i zdrowe podanie każdego dania.</p>
        <p>Popołudniami i wieczorami zachęcamy do skorzystania z naszej karty menu, bogatej w regionalne smaki i inspiracje kulinarne. Nasza przestronna sala bankietowa oraz profesjonalna obsługa tworzą idealne warunki na wyjątkowe uroczystości — wesela, komunie, urodziny i imprezy firmowe do 100 osób.</p>
        <div class="rest-links">
          <a href="/kontakt" class="btn-outline">Zapytaj o rezerwację sali</a>
        </div>
      </div>
    </div>
  </section>

  <!-- PHOTO GRID -->
  <section class="rest-gallery">
    <div class="rest-gallery-inner">
      {photos.map((p) => (
        <div class="rest-gallery-item">
          <img src={p.src} alt={p.alt} loading="lazy" />
        </div>
      ))}
    </div>
  </section>

  <!-- EVENT TYPES -->
  <section class="events">
    <div class="events-inner">
      <h2>Organizacja uroczystości</h2>
      <ul class="events-grid">
        <li>
          <h3>Wesela i przyjęcia</h3>
          <p>Elegancka sala bankietowa i profesjonalna obsługa tworzą niezapomnianą oprawę Twojego ślubu. Oferta dostosowana do indywidualnych oczekiwań.</p>
        </li>
        <li>
          <h3>Komunia i chrzciny</h3>
          <p>Uroczysty stół, catering i dekoracje — zadbamy o każdy szczegół Twojej rodzinnej uroczystości.</p>
        </li>
        <li>
          <h3>Urodziny i jubileusze</h3>
          <p>Przyjęcia okolicznościowe dla grup do 100 osób w nastrojowych wnętrzach restauracji.</p>
        </li>
        <li>
          <h3>Imprezy firmowe</h3>
          <p>Catering dla konferencji i eventów biznesowych — w połączeniu z naszymi salami konferencyjnymi lub w formie bankietu.</p>
        </li>
      </ul>
    </div>
  </section>

  <!-- BOOKING CTA -->
  <aside class="page-booking">
    <div class="page-booking-inner">
      <p>Zarezerwuj nocleg ze śniadaniem lub zapytaj o organizację uroczystości.</p>
      <a href="/kontakt" class="btn-book-page">Napisz do nas</a>
    </div>
  </aside>
</BaseLayout>

<style>
  /* HERO */
  .rest-hero {
    position: relative;
    min-height: 50vh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    background: var(--dark);
  }

  .rest-hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    opacity: 0.45;
  }

  .rest-hero-inner {
    position: relative;
    padding: 3rem 1.5rem;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  .kicker {
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.5rem;
  }

  .rest-hero-inner h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 400;
    color: var(--surface);
    line-height: 1.15;
    max-width: 20ch;
  }

  /* HOURS STRIP */
  .hours-strip {
    background: var(--dark);
    padding: 2rem 1.5rem;
    border-top: 1px solid rgba(255,255,255,0.08);
  }

  .hours-strip-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .hours-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .hours-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .hours-label {
    font-size: 0.875rem;
    color: var(--muted);
  }

  .hours-value {
    font-family: var(--font-heading);
    font-size: 1rem;
    color: var(--surface);
    white-space: nowrap;
  }

  @media (min-width: 640px) {
    .hours-strip-inner {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0;
    }

    .hours-item {
      flex-direction: column;
      justify-content: flex-start;
      gap: 0.35rem;
      padding: 1.25rem 1.5rem 1.25rem 0;
      border-bottom: none;
      border-right: 1px solid rgba(255,255,255,0.06);
    }

    .hours-item:nth-child(2),
    .hours-item:last-child {
      padding-left: 1.5rem;
      border-right: none;
    }
  }

  @media (min-width: 960px) {
    .hours-strip-inner { grid-template-columns: repeat(4, 1fr); }
    .hours-item { border-right: 1px solid rgba(255,255,255,0.06); }
    .hours-item:last-child { border-right: none; }
    .hours-item:nth-child(2) { border-right: 1px solid rgba(255,255,255,0.06); }
  }

  /* INTRO */
  .rest-intro {
    padding: 4rem 1.5rem;
    background: var(--bg);
  }

  .rest-intro-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .rest-intro-text h2 {
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    font-weight: 400;
    margin-bottom: 1rem;
  }

  .rest-intro-text p {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.75;
    max-width: 68ch;
    margin-bottom: 1rem;
  }

  .rest-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .btn-outline {
    display: inline-flex;
    padding: 0.6rem 1.5rem;
    background: transparent;
    color: var(--dark);
    text-decoration: none;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: 1px solid var(--dark);
    transition: background 0.2s, color 0.2s;
  }

  .btn-outline:hover {
    background: var(--dark);
    color: var(--surface);
  }

  /* PHOTO GRID */
  .rest-gallery {
    padding: 0 1.5rem 4rem;
    background: var(--bg);
  }

  .rest-gallery-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }

  @media (min-width: 640px) {
    .rest-gallery-inner { grid-template-columns: repeat(3, 1fr); }
  }

  .rest-gallery-item img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
    transition: opacity 0.3s;
  }

  .rest-gallery-item img:hover {
    opacity: 0.85;
  }

  /* EVENTS */
  .events {
    background: var(--surface);
    padding: 4rem 1.5rem;
    border-top: 1px solid var(--muted);
    border-bottom: 1px solid var(--muted);
  }

  .events-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .events-inner h2 {
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    font-weight: 400;
    margin-bottom: 2rem;
  }

  .events-grid {
    list-style: none;
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  }

  .events-grid li {
    padding: 1.5rem;
    border: 1px solid var(--muted);
  }

  .events-grid h3 {
    font-size: 1rem;
    font-weight: 700;
    font-family: var(--font-body);
    margin-bottom: 0.5rem;
  }

  .events-grid p {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  /* BOOKING CTA */
  .page-booking {
    background: var(--surface);
    border-top: 1px solid var(--muted);
    padding: 2.5rem 1.5rem;
  }

  .page-booking-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
  }

  .page-booking-inner p {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    max-width: 50ch;
  }

  .btn-book-page {
    display: inline-flex;
    padding: 0.65rem 1.75rem;
    background: var(--dark);
    color: var(--surface);
    text-decoration: none;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: 1px solid var(--dark);
    transition: background 0.2s, color 0.2s;
  }

  .btn-book-page:hover {
    background: transparent;
    color: var(--dark);
  }

  @media (min-width: 640px) {
    .page-booking-inner {
      flex-direction: row;
      align-items: center;
    }
    .page-booking-inner p { margin: 0; }
  }
</style>
