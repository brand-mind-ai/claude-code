---
import BaseLayout from "../layouts/BaseLayout.astro";
import hp from "../data/homepage.json";
const BOOKING_BASE = "https://be.guestsage.com/pl/0bf0dc4c-089f-42f4-8bf0-3ea22a76ad8a";
---

<BaseLayout
  title="Hotel Zacisze ★★★ Turawa – SPA, restauracja i konferencje nad Jeziorem Turawskim"
  description="Hotel Zacisze ★★★ w Turawie — 150 m od plaży Jeziora Turawskiego. Strefa SPA, restauracja z kuchnią regionalną, sale konferencyjne do 150 osób. Rezerwuj bezpośrednio — gwarancja najniższej ceny."
  canonicalPath="/"
>
  <!-- HERO -->
  <section class="hero">
    <img src={hp.hero.image} alt="Jezioro Turawskie z lotu ptaka" class="hero-img" />
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <p class="hero-subline">{hp.hero.subline}</p>
      <h1 class="hero-tagline">{hp.hero.tagline}</h1>
    </div>
    <div class="hero-booking-wrap">
      <form id="booking-form" class="booking-widget" novalidate>
        <div class="bw-field">
          <label for="arrival">Przyjazd</label>
          <input type="date" id="arrival" name="arrival" required />
        </div>
        <div class="bw-field">
          <label for="departure">Wyjazd</label>
          <input type="date" id="departure" name="departure" required />
        </div>
        <div class="bw-field bw-field--sm">
          <label for="persons">Osoby</label>
          <select id="persons" name="persons">
            <option value="1">1</option>
            <option value="2" selected>2</option>
            <option value="3">3</option>
            <option value="4">4</option>
            <option value="5">5+</option>
          </select>
        </div>
        <button type="submit" class="bw-submit">Sprawdź dostępność</button>
      </form>
    </div>
  </section>

  <!-- USP STRIP -->
  <div class="usp-strip">
    {hp.usps.map((u) => (
      <div class="usp-item">
        <span>{u.label}</span>
      </div>
    ))}
  </div>

  <!-- INTRO -->
  <section class="section intro-section">
    <div class="container intro-grid">
      <div class="intro-text">
        <h2>{hp.intro.heading}</h2>
        <p>{hp.intro.body}</p>
        <p>{hp.intro.body2}</p>
        <a href={BOOKING_BASE} target="_blank" rel="noopener noreferrer" class="btn-primary">Rezerwuj bezpośrednio</a>
      </div>
      <div class="intro-image">
        <img
          src="/assets/current/hotel/022.jpg"
          alt="Hotel Zacisze otoczony lasem sosnowym"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="section features-section">
    <div class="container">
      <h2 class="section-heading">Co oferujemy</h2>
      <div class="features-grid">
        {hp.features.map((f) => (
          <article class="feature-card">
            <h3>{f.title}</h3>
            <p>{f.body}</p>
            <a href={f.link} class="feature-link">{f.linkLabel} →</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- PACKAGES -->
  <section class="section packages-section">
    <div class="container">
      <h2 class="section-heading">Pakiety pobytowe</h2>
      <div class="packages-grid">
        {hp.packages.map((p) => (
          <a href={p.link} class="package-card">
            <div class="package-nights">{p.nights}</div>
            <h3 class="package-title">{p.title}</h3>
            <div class="package-price">{p.price}</div>
            <span class="package-cta">Szczegóły →</span>
          </a>
        ))}
      </div>
      <div class="packages-all">
        <a href="/pakiety_pobytowe" class="btn-outline">Zobacz wszystkie pakiety</a>
      </div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="section reviews-section">
    <div class="container">
      <h2 class="section-heading">Opinie gości</h2>
      <div class="reviews-grid">
        {hp.reviews.map((r) => (
          <blockquote class="review-card">
            <p>"{r.text}"</p>
            <footer>— {r.author}</footer>
          </blockquote>
        ))}
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="section cta-section">
    <div class="container cta-inner">
      <h2>Gotowy na odpoczynek?</h2>
      <p>Zarezerwuj bezpośrednio i skorzystaj z gwarancji najniższej ceny.<br/>Śniadanie i SPA w cenie każdego noclegu.</p>
      <a href={BOOKING_BASE} target="_blank" rel="noopener noreferrer" class="btn-primary">Sprawdź dostępność i rezerwuj</a>
    </div>
  </section>
</BaseLayout>

<script is:inline define:vars={{ BOOKING_BASE }}>
  function fmt(d) {
    return d.toISOString().split("T")[0];
  }

  const t1 = new Date(); t1.setDate(t1.getDate() + 1);
  const t2 = new Date(); t2.setDate(t2.getDate() + 2);

  const arrInput = document.getElementById("arrival");
  const depInput = document.getElementById("departure");
  if (arrInput) arrInput.value = fmt(t1);
  if (depInput) depInput.value = fmt(t2);

  document.getElementById("booking-form")?.addEventListener("submit", (e) => {
    e.preventDefault();
    const arrival = arrInput?.value;
    const departure = depInput?.value;
    const persons = document.getElementById("persons")?.value ?? "2";
    if (!arrival || !departure) return;
    const url = `${BOOKING_BASE}/offers?arrivalDate=${arrival}&departureDate=${departure}&personsCount=${persons}`;
    window.open(url, "_blank", "noopener,noreferrer");
  });
</script>

<style>
  /* ─── HERO ─────────────────────────────────────── */
  .hero {
    position: relative;
    height: 100svh;
    min-height: 520px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(19, 18, 16, 0.25) 0%,
      rgba(19, 18, 16, 0.1) 40%,
      rgba(19, 18, 16, 0.55) 75%,
      rgba(19, 18, 16, 0.75) 100%
    );
  }

  .hero-content {
    position: relative;
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2rem 1.5rem 0;
    color: #fafafa;
  }

  .hero-subline {
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.85;
    margin-bottom: 0.75rem;
  }

  .hero-tagline {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 6vw, 4.5rem);
    font-weight: 400;
    line-height: 1.15;
    color: #fafafa;
    max-width: 18ch;
  }

  /* Booking widget */
  .hero-booking-wrap {
    position: relative;
    padding: 1.5rem;
    display: flex;
    justify-content: center;
  }

  .booking-widget {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    background: rgba(250, 250, 250, 0.97);
    padding: 1.25rem 1.25rem 1rem;
    width: 100%;
    max-width: 520px;
  }

  .bw-field {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .bw-field label {
    font-size: 0.625rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-secondary);
  }

  .bw-field input,
  .bw-field select {
    border: 1px solid var(--muted);
    padding: 0.5rem 0.6rem;
    font-size: 0.875rem;
    font-family: var(--font-body);
    color: var(--text);
    background: transparent;
    appearance: none;
    -webkit-appearance: none;
    border-radius: 0;
    outline: none;
  }

  .bw-field input:focus,
  .bw-field select:focus {
    border-color: var(--dark);
  }

  .bw-submit {
    padding: 0.65rem 1rem;
    background: var(--dark);
    color: var(--surface);
    border: none;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    font-family: var(--font-body);
    transition: background 0.2s;
  }

  .bw-submit:hover {
    background: var(--text-secondary);
  }

  @media (min-width: 640px) {
    .booking-widget {
      flex-direction: row;
      align-items: flex-end;
      max-width: 800px;
    }

    .bw-field { flex: 1; }
    .bw-field--sm { flex: 0 0 5rem; }

    .bw-submit {
      flex: 0 0 auto;
      white-space: nowrap;
      align-self: flex-end;
    }
  }

  /* ─── USP STRIP ────────────────────────────────── */
  .usp-strip {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0;
    background: var(--dark);
  }

  .usp-item {
    padding: 0.85rem 1.5rem;
    color: var(--muted);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border-right: 1px solid rgba(205, 192, 177, 0.2);
  }

  .usp-item:last-child { border-right: none; }

  /* ─── SHARED SECTION STYLES ────────────────────── */
  .section {
    padding: 4rem 0;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-heading {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 400;
    margin-bottom: 2.5rem;
    text-align: center;
  }

  .btn-primary {
    display: inline-flex;
    padding: 0.75rem 2rem;
    background: var(--dark);
    color: var(--surface);
    text-decoration: none;
    font-size: 0.8125rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: 1px solid var(--dark);
    transition: background 0.2s, color 0.2s;
    margin-top: 1.5rem;
  }

  .btn-primary:hover {
    background: transparent;
    color: var(--dark);
  }

  .btn-outline {
    display: inline-flex;
    padding: 0.65rem 1.75rem;
    border: 1px solid var(--dark);
    color: var(--dark);
    text-decoration: none;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: background 0.2s, color 0.2s;
  }

  .btn-outline:hover {
    background: var(--dark);
    color: var(--surface);
  }

  /* ─── INTRO ────────────────────────────────────── */
  .intro-section { background: var(--bg); }

  .intro-grid {
    display: grid;
    gap: 3rem;
  }

  .intro-text h2 {
    font-size: clamp(1.6rem, 3vw, 2.5rem);
    font-weight: 400;
    margin-bottom: 1.25rem;
    line-height: 1.2;
  }

  .intro-text p {
    color: var(--text-secondary);
    line-height: 1.75;
    margin-bottom: 0.75rem;
  }

  .intro-image img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
  }

  @media (min-width: 768px) {
    .intro-grid {
      grid-template-columns: 1fr 1fr;
      align-items: center;
    }
  }

  /* ─── FEATURES ─────────────────────────────────── */
  .features-section { background: var(--surface); }

  .features-grid {
    display: grid;
    gap: 1.5rem;
  }

  .feature-card {
    padding: 2rem;
    border: 1px solid var(--muted);
    background: var(--bg);
  }

  .feature-card h3 {
    font-size: 1.25rem;
    font-weight: 400;
    margin-bottom: 0.75rem;
  }

  .feature-card p {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

  .feature-link {
    font-size: 0.8125rem;
    letter-spacing: 0.06em;
    text-decoration: none;
    color: var(--text);
    border-bottom: 1px solid currentColor;
    padding-bottom: 1px;
    transition: color 0.2s;
  }

  .feature-link:hover { color: var(--text-secondary); }

  @media (min-width: 768px) {
    .features-grid { grid-template-columns: repeat(3, 1fr); }
  }

  /* ─── PACKAGES ─────────────────────────────────── */
  .packages-section { background: var(--bg); }

  .packages-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .package-card {
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    border: 1px solid var(--muted);
    text-decoration: none;
    color: var(--text);
    transition: border-color 0.2s, background 0.2s;
  }

  .package-card:hover {
    border-color: var(--dark);
    background: var(--surface);
  }

  .package-nights {
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
  }

  .package-title {
    font-size: 1rem;
    font-weight: 400;
    margin-bottom: 0.5rem;
    flex: 1;
  }

  .package-price {
    font-size: 0.9375rem;
    font-family: var(--font-heading);
    color: var(--text-secondary);
    margin-bottom: 0.75rem;
  }

  .package-cta {
    font-size: 0.75rem;
    letter-spacing: 0.06em;
  }

  .packages-all { text-align: center; }

  @media (min-width: 768px) {
    .packages-grid { grid-template-columns: repeat(4, 1fr); }
  }

  /* ─── REVIEWS ───────────────────────────────────── */
  .reviews-section { background: var(--surface); }

  .reviews-grid {
    display: grid;
    gap: 1rem;
  }

  .review-card {
    padding: 1.5rem;
    border-left: 2px solid var(--muted);
    margin: 0;
  }

  .review-card p {
    font-style: italic;
    color: var(--text-secondary);
    line-height: 1.65;
    margin-bottom: 0.5rem;
  }

  .review-card footer {
    font-size: 0.8125rem;
    letter-spacing: 0.06em;
    color: var(--dark);
  }

  @media (min-width: 640px) {
    .reviews-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 960px) {
    .reviews-grid { grid-template-columns: repeat(3, 1fr); }
  }

  /* ─── FINAL CTA ─────────────────────────────────── */
  .cta-section {
    background: var(--dark);
    color: var(--surface);
    padding: 5rem 0;
  }

  .cta-inner {
    text-align: center;
  }

  .cta-inner h2 {
    font-size: clamp(1.75rem, 4vw, 3rem);
    font-weight: 400;
    color: var(--surface);
    margin-bottom: 1rem;
  }

  .cta-inner p {
    color: var(--muted);
    line-height: 1.7;
    margin-bottom: 0.5rem;
  }

  .cta-inner .btn-primary {
    background: var(--surface);
    color: var(--dark);
    border-color: var(--surface);
    margin-top: 2rem;
  }

  .cta-inner .btn-primary:hover {
    background: transparent;
    color: var(--surface);
  }
</style>
