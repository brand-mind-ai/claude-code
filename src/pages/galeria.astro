---

<BaseLayout
  title="Hotel Zacisze ★★★ Turawa – Galeria"
  description="Hotel Zacisze ★★★ w Turawie — zdjęcia hotelu, pokoi, strefy SPA, restauracji i okolic Jeziora Turawskiego."
  canonicalPath="/galeria"
  ogImage="/assets/current/hotel/Copy of 103.jpg"
>
  <div class="page-hero" style="background-image: url('/assets/current/hotel/Copy of 103.jpg')">
    <div class="page-hero-inner">
      <h1>Galeria</h1>
    </div>
  </div>

  <section class="gallery-section">
    <div class="gallery-inner">
      <div class="gallery-grid" id="gallery-grid">
        {images.map((img, i) => (
          <button
            class="gallery-item"
            aria-label={`Powiększ: ${img.alt}`}
            data-src={img.src}
            data-alt={img.alt}
            data-index={i}
          >
            <img src={img.src} alt={img.alt} loading="lazy" class="gallery-img" />
          </button>
        ))}
      </div>
    </div>
  </section>

  <div class="lightbox" id="lightbox" hidden role="dialog" aria-modal="true" aria-label="Powiększone zdjęcie">
    <button class="lightbox-close" id="lightbox-close" aria-label="Zamknij">&#10005;</button>
    <button class="lightbox-prev" id="lightbox-prev" aria-label="Poprzednie">&#8592;</button>
    <button class="lightbox-next" id="lightbox-next" aria-label="Następne">&#8594;</button>
    <img src="" alt="" id="lightbox-img" class="lightbox-img" />
  </div>
</BaseLayout>

<script>
  const items = Array.from(document.querySelectorAll<HTMLButtonElement>(".gallery-item"));
  const lightbox = document.getElementById("lightbox") as HTMLDivElement;
  const lbImg = document.getElementById("lightbox-img") as HTMLImageElement;
  let current = 0;

  function open(index: number) {
    current = index;
    const btn = items[current];
    lbImg.src = btn.dataset.src ?? "";
    lbImg.alt = btn.dataset.alt ?? "";
    lightbox.hidden = false;
    document.body.classList.add("nav-open");
  }

  function close() {
    lightbox.hidden = true;
    document.body.classList.remove("nav-open");
  }

  function prev() { open((current - 1 + items.length) % items.length); }
  function next() { open((current + 1) % items.length); }

  items.forEach((btn, i) => btn.addEventListener("click", () => open(i)));
  document.getElementById("lightbox-close")?.addEventListener("click", close);
  document.getElementById("lightbox-prev")?.addEventListener("click", prev);
  document.getElementById("lightbox-next")?.addEventListener("click", next);

  lightbox?.addEventListener("click", (e) => {
    if (e.target === lightbox) close();
  });

  document.addEventListener("keydown", (e) => {
    if (lightbox.hidden) return;
    if (e.key === "Escape") close();
    if (e.key === "ArrowLeft") prev();
    if (e.key === "ArrowRight") next();
  });
</script>

<style>
  .page-hero {
    height: 320px;
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: flex-end;
    padding-bottom: 2rem;
  }

  .page-hero-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1.25rem;
    width: 100%;
  }

  .page-hero h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    color: #fff;
    text-shadow: 0 2px 8px rgba(0,0,0,0.5);
  }

  .gallery-section {
    padding: 4rem 0;
  }

  .gallery-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1.25rem;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem;
  }

  @media (min-width: 640px) {
    .gallery-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (min-width: 1024px) {
    .gallery-grid { grid-template-columns: repeat(4, 1fr); }
  }

  .gallery-item {
    border: none;
    padding: 0;
    background: none;
    cursor: pointer;
    overflow: hidden;
    display: block;
    aspect-ratio: 4 / 3;
  }

  .gallery-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s, opacity 0.2s;
  }

  .gallery-item:hover .gallery-img {
    transform: scale(1.05);
    opacity: 0.9;
  }

  .lightbox {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.92);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 200;
  }

  .lightbox[hidden] { display: none; }

  .lightbox-img {
    max-width: 90vw;
    max-height: 88vh;
    object-fit: contain;
    display: block;
  }

  .lightbox-close,
  .lightbox-prev,
  .lightbox-next {
    position: absolute;
    background: rgba(255,255,255,0.1);
    border: none;
    color: #fff;
    font-size: 1.5rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
    width: 3rem;
    height: 3rem;
  }

  .lightbox-close { top: 1rem; right: 1rem; }
  .lightbox-prev { left: 1rem; top: 50%; transform: translateY(-50%); }
  .lightbox-next { right: 1rem; top: 50%; transform: translateY(-50%); }

  .lightbox-close:hover,
  .lightbox-prev:hover,
  .lightbox-next:hover { background: rgba(255,255,255,0.2); }
</style>
