---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const BOOKING_BASE = "https://be.guestsage.com/pl/0bf0dc4c-089f-42f4-8bf0-3ea22a76ad8a";

// Collect all individual package detail pages
const packages = await getCollection(
  "pl",
  (e: CollectionEntry<"pl">) => e.data.pageType === "package-detail" && e.data.status === "captured"
);

const packageMeta: Record<string, { nights: string; price: string }> = {
  "/boze_cialo_w_zaciszu_":   { nights: "3 noce", price: "od 620 zł / os." },
  "/wakacje-4-dni":           { nights: "4 noce", price: "od 608 zł / os." },
  "/wakacje_6_dni_nad_jeziorem_turawskim_2021": { nights: "6 nocy", price: "od 1025 zł / os." },
  "/wakacje_nad_jeziorem_turawskim_2021":       { nights: "8 nocy", price: "od 1418 zł / os." },
  "/wspanialy-weekend":       { nights: "3 noce", price: "od 615 zł / os." },
  "/zawsze_mlodzi_":          { nights: "3 noce", price: "od 610 zł / os." },
  "/lejdis":                  { nights: "2 noce", price: "od 370 zł / os." },
  "/rocznica_slubu":          { nights: "3 noce", price: "od 705 zł / os." },
};

type ProcessedPackage = { path: string; title: string; heroImage: string | undefined; meta: { nights: string; price: string } | undefined };
const processedPackages: ProcessedPackage[] = packages.map((pkg: CollectionEntry<"pl">) => ({
  path: pkg.data.canonicalPath,
  title: pkg.data.title.replace(/^Hotel Zacisze.*?- /i, "").replace(/\s★★★.*$/, "").trim(),
  heroImage: pkg.data.heroImage,
  meta: packageMeta[pkg.data.canonicalPath] as { nights: string; price: string } | undefined,
}));
---

<BaseLayout
  title="Pakiety pobytowe — Hotel Zacisze ★★★ Turawa"
  description="Pakiety pobytowe Hotelu Zacisze Turawa — długi weekend, wakacje nad Jeziorem Turawskim, SPA, pakiet dla par. Śniadania i SPA w cenie, gwarancja najniższej ceny."
  canonicalPath="/pakiety_pobytowe"
  ogImage="/assets/current/hotel/490175062_1194433046020758_6544292665433459308_n.jpg"
>
  <!-- HERO -->
  <header class="pkg-hero">
    <img
      src="/assets/current/hotel/490175062_1194433046020758_6544292665433459308_n.jpg"
      alt="Jezioro Turawskie"
      class="pkg-hero-img"
    />
    <div class="pkg-hero-inner">
      <p class="kicker">Pakiety pobytowe</p>
      <h1>Zaplanuj swój wypoczynek</h1>
      <p class="sub">Śniadania i Strefa SPA w cenie każdego pakietu</p>
    </div>
  </header>

  <!-- INCLUDED ALWAYS -->
  <section class="included">
    <div class="included-inner">
      <ul class="included-list">
        <li>
          <span class="included-icon">🍳</span>
          <span>Śniadanie bufetowe</span>
        </li>
        <li>
          <span class="included-icon">🧖</span>
          <span>Strefa SPA bez limitu (16:00–22:00)</span>
        </li>
        <li>
          <span class="included-icon">🅿️</span>
          <span>Bezpłatny parking</span>
        </li>
        <li>
          <span class="included-icon">📶</span>
          <span>Wi-Fi w całym obiekcie</span>
        </li>
        <li>
          <span class="included-icon">🏊</span>
          <span>Basen zewnętrzny (sezon letni)</span>
        </li>
        <li>
          <span class="included-icon">🛎</span>
          <span>Gwarancja najniższej ceny</span>
        </li>
      </ul>
    </div>
  </section>

  <!-- PACKAGES GRID -->
  <section class="packages">
    <div class="packages-inner">
      <ul class="packages-grid">
        {processedPackages.map((pkg) => (
          <li class="pkg-card">
            {pkg.heroImage && (
              <div class="pkg-card-img-wrap">
                <img src={pkg.heroImage} alt={pkg.title} loading="lazy" />
              </div>
            )}
            <div class="pkg-card-body">
              <h2>{pkg.title}</h2>
              {pkg.meta && (
                <div class="pkg-meta">
                  <span class="pkg-nights">{pkg.meta.nights}</span>
                  <span class="pkg-price">{pkg.meta.price}</span>
                </div>
              )}
              <div class="pkg-actions">
                <a href={pkg.path} class="btn-details">Szczegóły</a>
                <a href={BOOKING_BASE} target="_blank" rel="noopener noreferrer" class="btn-book">Rezerwuj</a>
              </div>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- BOOKING CTA -->
  <aside class="page-booking">
    <div class="page-booking-inner">
      <p>Rezerwuj bezpośrednio — gwarancja najniższej ceny, śniadanie i SPA w cenie.</p>
      <a href={BOOKING_BASE} target="_blank" rel="noopener noreferrer" class="btn-book-page">
        Sprawdź wszystkie terminy
      </a>
    </div>
  </aside>
</BaseLayout>

<style>
  /* HERO */
  .pkg-hero {
    position: relative;
    min-height: 45vh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    background: var(--dark);
  }

  .pkg-hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0.45;
  }

  .pkg-hero-inner {
    position: relative;
    padding: 3rem 1.5rem;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  .kicker {
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.5rem;
  }

  .pkg-hero-inner h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 400;
    color: var(--surface);
    line-height: 1.15;
    max-width: 18ch;
  }

  .sub {
    margin-top: 0.75rem;
    font-size: 0.9375rem;
    color: var(--muted);
  }

  /* INCLUDED */
  .included {
    background: var(--dark);
    border-top: 1px solid rgba(255,255,255,0.08);
    padding: 2rem 1.5rem;
  }

  .included-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .included-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 2rem;
  }

  .included-list li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--muted);
  }

  .included-icon {
    font-size: 1rem;
    flex-shrink: 0;
  }

  /* PACKAGES */
  .packages {
    padding: 4rem 1.5rem;
    background: var(--bg);
  }

  .packages-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .packages-grid {
    list-style: none;
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .packages-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 960px) {
    .packages-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .pkg-card {
    background: var(--surface);
    border: 1px solid var(--muted);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .pkg-card-img-wrap {
    aspect-ratio: 16/9;
    overflow: hidden;
  }

  .pkg-card-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .pkg-card:hover .pkg-card-img-wrap img {
    transform: scale(1.03);
  }

  .pkg-card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
  }

  .pkg-card-body h2 {
    font-size: 1.125rem;
    font-weight: 400;
    line-height: 1.3;
  }

  .pkg-meta {
    display: flex;
    gap: 1rem;
    align-items: baseline;
  }

  .pkg-nights {
    font-size: 0.8125rem;
    color: var(--text-secondary);
    letter-spacing: 0.04em;
  }

  .pkg-price {
    font-family: var(--font-heading);
    font-size: 1rem;
    color: var(--text);
  }

  .pkg-actions {
    display: flex;
    gap: 0.75rem;
    margin-top: auto;
    padding-top: 0.5rem;
  }

  .btn-details,
  .btn-book {
    display: inline-flex;
    padding: 0.5rem 1.25rem;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
    border: 1px solid var(--dark);
  }

  .btn-details {
    background: transparent;
    color: var(--dark);
  }

  .btn-details:hover {
    background: var(--dark);
    color: var(--surface);
  }

  .btn-book {
    background: var(--dark);
    color: var(--surface);
  }

  .btn-book:hover {
    background: transparent;
    color: var(--dark);
  }

  /* BOOKING CTA */
  .page-booking {
    background: var(--surface);
    border-top: 1px solid var(--muted);
    padding: 2.5rem 1.5rem;
  }

  .page-booking-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
  }

  .page-booking-inner p {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    max-width: 50ch;
  }

  .btn-book-page {
    display: inline-flex;
    padding: 0.65rem 1.75rem;
    background: var(--dark);
    color: var(--surface);
    text-decoration: none;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: 1px solid var(--dark);
    transition: background 0.2s, color 0.2s;
  }

  .btn-book-page:hover {
    background: transparent;
    color: var(--dark);
  }

  @media (min-width: 640px) {
    .page-booking-inner {
      flex-direction: row;
      align-items: center;
    }
    .page-booking-inner p { margin: 0; }
  }
</style>
