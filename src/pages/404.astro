---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Strona nie istnieje — Hotel Zacisze ★★★ Turawa"
  description="Nie znaleziono strony. Wróć na stronę główną Hotelu Zacisze w Turawie."
>
  <div class="not-found">
    <div class="not-found-inner">
      <p class="not-found-code">404</p>
      <h1>Strona nie istnieje</h1>
      <p class="not-found-msg">Przepraszamy — ta strona nie istnieje lub została przeniesiona.</p>
      <div class="not-found-actions">
        <a href="/" class="btn-primary">Strona główna</a>
        <a href="/pokoje" class="btn-secondary">Pokoje</a>
        <a href="/kontakt" class="btn-secondary">Kontakt</a>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .not-found {
    min-height: calc(100svh - 4.5rem);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 1.5rem;
    background: var(--bg);
  }

  .not-found-inner {
    text-align: center;
    max-width: 40ch;
  }

  .not-found-code {
    font-family: var(--font-heading);
    font-size: clamp(4rem, 15vw, 8rem);
    font-weight: 400;
    color: var(--muted);
    line-height: 1;
    margin-bottom: 1rem;
  }

  h1 {
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    font-weight: 400;
    color: var(--text);
    margin-bottom: 0.75rem;
  }

  .not-found-msg {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  .not-found-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }

  .btn-primary,
  .btn-secondary {
    display: inline-flex;
    padding: 0.65rem 1.75rem;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    border: 1px solid var(--dark);
    transition: background 0.2s, color 0.2s;
  }

  .btn-primary {
    background: var(--dark);
    color: var(--surface);
  }

  .btn-primary:hover {
    background: transparent;
    color: var(--dark);
  }

  .btn-secondary {
    background: transparent;
    color: var(--dark);
  }

  .btn-secondary:hover {
    background: var(--dark);
    color: var(--surface);
  }
</style>
