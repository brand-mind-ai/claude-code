---
import { getCollection, type CollectionEntry } from "astro:content";
import ContentLayout from "../layouts/ContentLayout.astro";

export async function getStaticPaths() {
  // These paths have dedicated page files — exclude to avoid route conflicts
  const DEDICATED = new Set(["/galeria", "/kontakt", "/pokoje", "/spa", "/restauracja", "/pakiety_pobytowe"]);

  const entries = await getCollection(
    "pl",
    (e: CollectionEntry<"pl">) =>
      e.data.status === "captured" &&
      e.data.canonicalPath !== "/" &&
      !DEDICATED.has(e.data.canonicalPath)
  );

  return entries.map((entry: CollectionEntry<"pl">) => ({
    params: { slug: entry.data.canonicalPath.replace(/^\//, "") },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<"pl">;
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const { title, seoTitle, description, canonicalPath, heroImage, pageType } = entry.data;
---

<ContentLayout
  title={title}
  seoTitle={seoTitle}
  description={description}
  canonicalPath={canonicalPath}
  heroImage={heroImage}
  pageType={pageType}
>
  <Content />
</ContentLayout>
