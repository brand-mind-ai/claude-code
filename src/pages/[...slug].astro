---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const DEDICATED = new Set([
  "/", "/pokoje", "/spa", "/restauracja", "/konferencje",
  "/pakiety_pobytowe", "/galeria", "/kontakt"
]);

const BOOKING_BASE = "https://be.guestsage.com/pl/0bf0dc4c-089f-42f4-8bf0-3ea22a76ad8a";

export async function getStaticPaths() {
  const entries = await getCollection(
    "pl",
    (e: CollectionEntry<"pl">) =>
      e.data.status === "captured" &&
      e.data.canonicalPath !== "/" &&
      !new Set(["/pokoje","/spa","/restauracja","/konferencje","/pakiety_pobytowe","/galeria","/kontakt"]).has(e.data.canonicalPath ?? "")
  );

  return entries.map((entry: CollectionEntry<"pl">) => ({
    params: { slug: entry.data.canonicalPath.replace(/^\//, "") },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<"pl">;
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const { title, seoTitle, description, canonicalPath, heroImage, pageType } = entry.data;

const PAGE_KICKER: Record<string, string> = {
  "room-detail": "Pokoje",
  "package-detail": "Pakiety pobytowe",
};
const kicker = PAGE_KICKER[pageType ?? ""] ?? null;

const BACK_LINK: Record<string, { href: string; label: string }> = {
  "room-detail": { href: "/pokoje", label: "← Wszystkie pokoje" },
  "package-detail": { href: "/pakiety_pobytowe", label: "← Wszystkie oferty" },
};
const backLink = BACK_LINK[pageType ?? ""] ?? null;

const showBookingCta = !["contact", "legal", "jobs"].includes(pageType ?? "");
---

<BaseLayout
  title={seoTitle ?? title}
  description={description}
  canonicalPath={canonicalPath}
  ogImage={heroImage}
>
  <div class="page-wrap">
    <header class:list={["page-header", heroImage && "page-header--photo"]}>
      {heroImage && (
        <img src={heroImage} alt="" class="page-header-img" fetchpriority="high" decoding="async" />
      )}
      <div class:list={["page-header-inner", heroImage && "page-header-inner--overlay"]}>
        {kicker && <p class="page-kicker">{kicker}</p>}
        <h1>{title.replace(/\s[–—-]\s.*$/, "").replace(/\s★★★.*$/, "").trim()}</h1>
      </div>
    </header>

    <main class="prose-wrap">
      {backLink && <a href={backLink.href} class="back-link">{backLink.label}</a>}
      <div class="prose">
        <Content />
      </div>
    </main>

    {showBookingCta && (
      <aside class="page-booking">
        <div class="page-booking-inner">
          <p>Rezerwuj bezpośrednio — gwarancja najniższej ceny, śniadanie i SPA w cenie.</p>
          <a href={BOOKING_BASE} target="_blank" rel="noopener noreferrer" class="btn-book">
            Sprawdź dostępność i rezerwuj
          </a>
        </div>
      </aside>
    )}
  </div>
</BaseLayout>

<style>
  .page-wrap { display: flex; flex-direction: column; }

  .page-header {
    background: var(--dark);
    padding: 4rem 1.25rem 3rem;
    position: relative;
    overflow: hidden;
  }
  .page-header--photo { min-height: 40vh; display: flex; align-items: flex-end; }
  .page-header-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0.45; }
  .page-header-inner { position: relative; max-width: 1280px; margin: 0 auto; width: 100%; }
  .page-header-inner--overlay { padding: 2rem 0; }
  .page-kicker { font-size: 0.75rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); margin-bottom: 0.75rem; }
  .page-header h1 { font-size: clamp(1.75rem, 4vw, 3rem); font-weight: 400; color: var(--surface); line-height: 1.2; max-width: 20ch; }

  .prose-wrap { flex: 1; padding: 3rem 1.25rem; max-width: 1280px; margin: 0 auto; width: 100%; }
  .back-link { display: inline-block; font-size: 0.8125rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--text-secondary); text-decoration: none; margin-bottom: 1.75rem; transition: color 0.2s; }
  .back-link:hover { color: var(--text); }
  .prose { max-width: 72ch; }
  .prose :global(h2) { font-size: 1.5rem; font-weight: 400; margin: 2rem 0 0.75rem; }
  .prose :global(h3) { font-size: 1.125rem; font-weight: 700; margin: 1.5rem 0 0.5rem; }
  .prose :global(h4) { font-size: 1rem; font-weight: 700; margin: 1.25rem 0 0.4rem; }
  .prose :global(p) { color: var(--text-secondary); line-height: 1.75; margin-bottom: 1rem; }
  .prose :global(ul) { padding-left: 1.25rem; margin-bottom: 1rem; }
  .prose :global(li) { color: var(--text-secondary); line-height: 1.7; margin-bottom: 0.25rem; }
  .prose :global(a) { color: var(--text); text-underline-offset: 3px; }
  .prose :global(a:hover) { color: var(--text-secondary); }
  .prose :global(strong) { color: var(--text); font-weight: 600; }

  .page-booking { background: var(--surface); border-top: 1px solid var(--muted); padding: 2.5rem 1.25rem; }
  .page-booking-inner { max-width: 1280px; margin: 0 auto; display: flex; flex-direction: column; align-items: flex-start; gap: 1rem; }
  .page-booking-inner p { font-size: 0.9375rem; color: var(--text-secondary); max-width: 50ch; }
  @media (min-width: 640px) { .page-booking-inner { flex-direction: row; align-items: center; } .page-booking-inner p { margin: 0; } }
  .btn-book {
    display: inline-flex;
    padding: 0.65rem 1.75rem;
    background: var(--dark);
    color: var(--surface);
    text-decoration: none;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: 1px solid var(--dark);
    transition: background 0.2s, color 0.2s;
    white-space: nowrap;
  }
  .btn-book:hover { background: transparent; color: var(--dark); }
</style>
