---
import siteData from "../data/site.json";
import navData from "../data/navigation.json";

const { phone, mapsUrl, facebookUrl, instagramUrl } = siteData;
const { primary: navLinks } = navData;
const bookingUrl = "https://be.guestsage.com/pl/0bf0dc4c-089f-42f4-8bf0-3ea22a76ad8a";
const phoneHref = `tel:${phone.replace(/\s/g, "")}`;
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="logo-link" aria-label="Hotel Zacisze – strona główna">
      <img src="/zacisze-logo.svg" alt="Hotel Zacisze" class="logo" width="180" height="56" />
    </a>

    <nav class="primary-nav" aria-label="Nawigacja główna">
      <ul>
        {navLinks.map((item) => (
          <li><a href={item.path}>{item.label}</a></li>
        ))}
      </ul>
    </nav>

    <div class="header-utils">
      <a href={facebookUrl} class="util-icon" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
        </svg>
      </a>
      <a href={instagramUrl} class="util-icon" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <circle cx="12" cy="12" r="4"/>
          <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
        </svg>
      </a>
      <a href={mapsUrl} class="util-icon" target="_blank" rel="noopener noreferrer" aria-label="Lokalizacja na mapie">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
          <circle cx="12" cy="10" r="3"/>
        </svg>
      </a>
      <a href={phoneHref} class="util-phone">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.45 2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 5.28 5.28l.82-.82a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.72 2.03z"/>
        </svg>
        <span>{phone}</span>
      </a>
      <a href={bookingUrl} class="btn-book" target="_blank" rel="noopener noreferrer">Rezerwuj</a>
    </div>

    <button class="nav-toggle" aria-expanded="false" aria-controls="mobile-nav" aria-label="Otwórz menu">
      <span class="burger"></span>
    </button>
  </div>

  <div class="mobile-nav" id="mobile-nav" hidden>
    <nav aria-label="Nawigacja mobilna">
      <ul>
        {navLinks.map((item) => (
          <li><a href={item.path}>{item.label}</a></li>
        ))}
      </ul>
    </nav>
    <div class="mobile-bottom">
      <div class="mobile-icons">
        <a href={facebookUrl} class="util-icon" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
          </svg>
        </a>
        <a href={instagramUrl} class="util-icon" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <circle cx="12" cy="12" r="4"/>
            <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
          </svg>
        </a>
        <a href={mapsUrl} class="util-icon" target="_blank" rel="noopener noreferrer" aria-label="Mapa">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
        </a>
      </div>
      <a href={phoneHref} class="mobile-phone">{phone}</a>
      <a href={bookingUrl} class="btn-book" target="_blank" rel="noopener noreferrer">Rezerwuj</a>
    </div>
  </div>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>(".nav-toggle");
  const mobileNav = document.getElementById("mobile-nav");

  toggle?.addEventListener("click", () => {
    const expanded = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", String(!expanded));
    toggle.setAttribute("aria-label", expanded ? "Otwórz menu" : "Zamknij menu");
    if (mobileNav) mobileNav.hidden = expanded;
    document.body.classList.toggle("nav-open", !expanded);
  });

  // Close on nav link click (single-page feel)
  mobileNav?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      if (mobileNav) mobileNav.hidden = true;
      toggle?.setAttribute("aria-expanded", "false");
      toggle?.setAttribute("aria-label", "Otwórz menu");
      document.body.classList.remove("nav-open");
    });
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--bg);
    border-bottom: 1px solid var(--muted);
  }

  .header-inner {
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    align-items: center;
    gap: 1rem;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 4.5rem;
  }

  .logo-link {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo {
    height: 2.5rem;
    width: auto;
  }

  /* Primary nav — hidden on mobile */
  .primary-nav {
    display: none;
  }

  .primary-nav ul {
    list-style: none;
    display: flex;
    gap: 0.25rem;
    justify-content: center;
  }

  .primary-nav a {
    display: block;
    padding: 0.4rem 0.75rem;
    font-size: 0.8125rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--text);
    transition: color 0.2s;
  }

  .primary-nav a:hover {
    color: var(--text-secondary);
  }

  /* Utils row — hidden on mobile except toggle */
  .header-utils {
    display: none;
    align-items: center;
    gap: 0.75rem;
  }

  .util-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    color: var(--text);
    text-decoration: none;
    transition: color 0.2s;
  }

  .util-icon:hover {
    color: var(--text-secondary);
  }

  .util-icon svg {
    width: 1.1rem;
    height: 1.1rem;
  }

  .util-phone {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8125rem;
    color: var(--text);
    text-decoration: none;
    transition: color 0.2s;
    white-space: nowrap;
  }

  .util-phone:hover {
    color: var(--text-secondary);
  }

  .util-phone svg {
    width: 0.9rem;
    height: 0.9rem;
    flex-shrink: 0;
  }

  .btn-book {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 1.1rem;
    background: var(--dark);
    color: var(--surface);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    border: 1px solid var(--dark);
    transition: background 0.2s, color 0.2s;
    white-space: nowrap;
  }

  .btn-book:hover {
    background: transparent;
    color: var(--dark);
  }

  /* Hamburger toggle — visible on mobile */
  .nav-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    color: var(--text);
    grid-column: 4;
  }

  .burger {
    display: block;
    width: 1.4rem;
    height: 2px;
    background: currentColor;
    position: relative;
    transition: background 0.2s;
  }

  .burger::before,
  .burger::after {
    content: "";
    position: absolute;
    left: 0;
    width: 100%;
    height: 2px;
    background: currentColor;
    transition: transform 0.25s;
  }

  .burger::before { top: -6px; }
  .burger::after  { top:  6px; }

  [aria-expanded="true"] .burger {
    background: transparent;
  }

  [aria-expanded="true"] .burger::before {
    transform: translateY(6px) rotate(45deg);
  }

  [aria-expanded="true"] .burger::after {
    transform: translateY(-6px) rotate(-45deg);
  }

  /* Mobile nav */
  .mobile-nav {
    background: var(--bg);
    border-top: 1px solid var(--muted);
    padding: 1.5rem;
  }

  .mobile-nav[hidden] {
    display: none;
  }

  .mobile-nav nav ul {
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  .mobile-nav nav a {
    display: block;
    padding: 0.75rem 0;
    font-size: 1.1rem;
    font-family: var(--font-heading);
    text-decoration: none;
    color: var(--text);
    border-bottom: 1px solid color-mix(in srgb, var(--muted) 50%, transparent);
  }

  .mobile-nav nav a:hover {
    color: var(--text-secondary);
  }

  .mobile-bottom {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .mobile-icons {
    display: flex;
    gap: 1rem;
  }

  .mobile-phone {
    font-size: 1rem;
    color: var(--text);
    text-decoration: none;
  }

  .mobile-nav .btn-book {
    align-self: flex-start;
    padding: 0.6rem 1.5rem;
    font-size: 0.8125rem;
  }

  /* Prevent scroll when mobile nav is open */
  :global(body.nav-open) {
    overflow: hidden;
  }

  /* Desktop breakpoint */
  @media (min-width: 960px) {
    .primary-nav {
      display: block;
    }

    .header-utils {
      display: flex;
    }

    .nav-toggle {
      display: none;
    }

    .header-inner {
      grid-template-columns: auto 1fr auto;
    }
  }
</style>
